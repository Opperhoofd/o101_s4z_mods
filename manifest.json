{
    "manifest_version": 1,
    "name": "O101 for S4Z",
    "description": "A better nearby riders MOD",
    "author": "Onno Aphinan",
    "website_url": "https://github.com/O101",
    "version": "0.0.1",
    "web_root": "pages",
    "windows": [
    {
        "file": "pages/nearby-race.html",
        "id": "O101-nearby-race",
        "name": "O101 - nearby race",
        "description": "A nearby riders optimized for racing",
        "always_visible": true,
        "overlay": true,
        "frame": false,
        "default_bounds": {
            "width": 600,
            "height": 250,
            "x": -300,
            "y": 100
        }
    },
    {
        "file": "pages/curwatch-race.html",
        "id": "O101-curwatch-race",
        "name": "O101 - currently watching race",
        "description": "A currently watching window optimized for racing",
        "always_visible": true,
        "overlay": true,
        "frame": false,
        "default_bounds": {
            "width": 300,
            "height": 250,
            "x": -300,
            "y": 100
        }
    }]
}
